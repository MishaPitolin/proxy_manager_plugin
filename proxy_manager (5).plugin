#  REGEX
# ═══════════════════════════════════════════════════════════════════

MTPROTO_RE = re.compile(
    r"(?:tg://proxy|https://t\.me/proxy)\?server=([\w.\-]+)[&?](?:amp;)?port=(\d+)[&?](?:amp;)?secret=([\w\d+/=\-]+)",
    re.IGNORECASE,
)
SOCKS5_RE = re.compile(
    r"(?:tg://socks|https://t\.me/socks)\?server=([\w.\-]+)[&?](?:amp;)?port=(\d+)"
    r"(?:[&?](?:amp;)?user=([\w%\-]*))?(?:[&?](?:amp;)?pass=([\w%\-]*))?",
    re.IGNORECASE,
)


