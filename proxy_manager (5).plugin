#  ХУКИ
# ═══════════════════════════════════════════════════════════════════

def _alive(pl): return pl is not None and pl.active and not pl.unloading

class BlockProxyHook(MethodReplacement):
    def __init__(self, p): self.pl = p
    def replace_hooked_method(self, p):
        if not _alive(self.pl): return p.args[0] if p.args else None
        run_on_ui_thread(lambda: BulletinHelper.show_error("⛔ Proxy Manager: изменение заблокировано"))
        self.pl.restore_proxy(); return self.pl.proxy_info

class BlockDeleteHook(MethodReplacement):
    def __init__(self, p): self.pl = p
    def replace_hooked_method(self, p):
        if not _alive(self.pl): return None
        run_on_ui_thread(lambda: BulletinHelper.show_error("⛔ Proxy Manager: удаление заблокировано"))
        self.pl.restore_proxy(); return None

class ProxyEnabledHook(MethodHook):
    def __init__(self, p): self.pl = p
    def after_hooked_method(self, p):
        if _alive(self.pl): p.setResult(True)

class CurrentProxyHook(MethodHook):
    def __init__(self, p): self.pl = p
    def after_hooked_method(self, p):
        if _alive(self.pl) and self.pl.proxy_info is not None: p.setResult(self.pl.proxy_info)

class ConnectionStateHook(MethodHook):
    def __init__(self, p): self.pl = p
    def after_hooked_method(self, p):
        if not _alive(self.pl): return
        try:
            if p.getResult() in (3, 4):
                threading.Thread(target=self.pl._on_connection_stuck, daemon=True).start()
        except: pass

class _CheckProxyListHook(MethodHook):
    def __init__(self, plg): self._p = plg
    def before_hooked_method(self, param):
        try:
            if self._p.get_setting("ping_mode", 0) != 1: param.setResult(None)
        except: pass

class _CreateViewHook(MethodHook):
    def __init__(self, plg): self._p = plg
    def after_hooked_method(self, param):
        self._p._add_action_buttons(param.thisObject)

class _CellSetProxyHook(MethodHook):
    def __init__(self, plg): self._p = plg
    def after_hooked_method(self, param):
        try:
            cell = param.thisObject; info = param.args[0]
            if not info: return
            addr = str(getattr(info, "address","") or "")
            tv = get_private_field(cell, "textView")
            if tv is None: return
            prefix = ""
            if self._p.get_setting("show_dpi", True):
                try:
                    cls = _classify_proxy(info)
                    bk = cls["badge_key"]
                    prefix += self._p.get_setting(f"badge_{bk}", cls["badge"]) or cls["badge"]
                except: pass
            if self._p.get_setting("show_geo", True):
                d = self._p._geo_fresh(addr)
                if d: prefix += d.get("flag","")
                elif not self._p._ping_busy: self._p._geo_request(addr)
            base = f"{addr}:{info.port}"
            tv.setText(f"{prefix} {base}".strip() if prefix else base)
        except: pass

class _CellUpdateStatusHook(MethodHook):
    def __init__(self, plg): self._p = plg
    def after_hooked_method(self, param):
        try:
            cell = param.thisObject; info = get_private_field(cell, "currentInfo")
            if not info: return
            vv = get_private_field(cell, "valueTextView")
            if vv is None: return
            if self._p.get_setting("ping_color", True):
                try:
                    if getattr(info, "available", False):
                        vv.setTextColor(_ping_color(int(getattr(info, "ping", 0) or 0)))
                    else: vv.setTextColor(0xFF9E9E9E)
                except: pass
            if self._p.get_setting("show_geo", True):
                addr = str(getattr(info, "address","") or "")
                d = self._p._geo_fresh(addr)
                if d and d.get("isp"):
                    cur = str(vv.getText() or "")
                    if d["isp"] not in cur: vv.setText(f"{cur} · {d['isp']}")
        except: pass


