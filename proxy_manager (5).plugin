#  АВТО-ОБНОВЛЕНИЕ ПЛАГИНА
# ═══════════════════════════════════════════════════════════════════

class PluginUpdater:
    def __init__(self, plugin): self.plugin = plugin
    def check_and_update(self, silent=False):
        threading.Thread(target=self._do, args=(silent,), daemon=True, name="pm-updater").start()
    def _do(self, silent):
        try:
            ctx = ssl.create_default_context()
            with urllib.request.urlopen(
                urllib.request.Request(UPDATE_CHECK_URL, headers={"User-Agent": "Mozilla/5.0"}),
                timeout=10, context=ctx) as r:
                info = json.loads(r.read().decode())
            rv = info.get("version","0.0.0")
            if self._gt(rv, PLUGIN_VERSION):
                run_on_ui_thread(lambda: BulletinHelper.show_info(f"🆕 Обновление {rv} — устанавливаю..."))
                self._install(info.get("url", UPDATE_PLUGIN_URL))
            elif not silent:
                run_on_ui_thread(lambda: BulletinHelper.show_info(f"✅ Версия {PLUGIN_VERSION} актуальна"))
        except Exception as e:
            if not silent:
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"❌ Ошибка обновления: {e}"))
    def _install(self, url):
        try:
            ctx = ssl.create_default_context()
            with urllib.request.urlopen(
                urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"}),
                timeout=30, context=ctx) as r:
                data = r.read()

            # Сохраняем поверх текущего файла в папку плагинов
            plugins_dir = get_plugins_dir()
            plugin_path = os.path.join(plugins_dir, "proxy_manager.plugin")
            with open(plugin_path, "wb") as f:
                f.write(data)
            self.plugin.log(f"Файл обновлён: {plugin_path}")

            # Пробуем перезагрузить плагин через PythonPluginsEngine
            run_on_ui_thread(lambda: self._reload_self(plugin_path))

        except Exception as e:
            run_on_ui_thread(lambda: BulletinHelper.show_error(f"❌ Ошибка установки: {e}"))
            self.plugin.log(f"Ошибка обновления: {e}")

    def _reload_self(self, plugin_path: str):
        """Перезагружает текущий плагин через PythonPluginsEngine."""
        try:
            # Получаем движок плагинов через хук
            engine_cls = find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine_cls is None:
                raise Exception("PythonPluginsEngine не найден")

            # Получаем singleton экземпляр движка
            engine = None
            try:
                get_instance = engine_cls.getClass().getDeclaredMethod("getInstance")
                get_instance.setAccessible(True)
                engine = get_instance.invoke(None)
            except Exception:
                pass

            # Fallback: через статическое поле instance
            if engine is None:
                try:
                    f = engine_cls.getClass().getDeclaredField("instance")
                    f.setAccessible(True)
                    engine = f.get(None)
                except Exception:
                    pass

            if engine is None:
                raise Exception("Не удалось получить экземпляр движка")

            # Выгружаем плагин
            try:
                unload = engine_cls.getClass().getDeclaredMethod(
                    "unloadPlugin", find_class("java.lang.String"))
                unload.setAccessible(True)
                unload.invoke(engine, "proxy_manager")
            except Exception as e:
                self.plugin.log(f"unload: {e}")

            # Небольшая задержка
            import time as _t; _t.sleep(0.5)

            # Загружаем обновлённый файл
            try:
                load = engine_cls.getClass().getDeclaredMethod(
                    "loadPluginFromFile", find_class("java.io.File"))
                load.setAccessible(True)
                file_cls = find_class("java.io.File")
                f = file_cls.getConstructor(find_class("java.lang.String")).newInstance(plugin_path)
                load.invoke(engine, f)
                BulletinHelper.show_success("✅ Плагин обновлён и перезагружен!")
                self.plugin.log("Плагин успешно перезагружен")
                return
            except Exception as e:
                self.plugin.log(f"loadPluginFromFile: {e}")

            # Если не вышло — просим пользователя перезагрузить вручную
            BulletinHelper.show_success(
                "✅ Файл обновлён! Выключи и включи плагин в списке.")

        except Exception as e:
            self.plugin.log(f"_reload_self: {e}")
            BulletinHelper.show_success(
                "✅ Файл обновлён! Выключи и включи плагин в списке.")
    @staticmethod
    def _gt(a, b):
        try: return [int(x) for x in a.split(".")] > [int(x) for x in b.split(".")]
        except: return False


