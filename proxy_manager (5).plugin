class ProxyManagerPlugin(BasePlugin):

    def __init__(self):
        super().__init__()
        self.active = False; self.unloading = False; self.loading = False
        self.proxy_list: List[Dict] = []
        self.current_index = 0; self.proxy_info = None
        self.lock = threading.RLock()
        self._all_hooks: List = []
        self._monitor_running = False; self._network_running = False
        self._refresh_running = False; self._reconnect_pending = False
        self._reconnect_attempts = 0; self._stuck_cooldown = 0.0
        self._bad_ping_streak = 0
        self._ping_busy = False; self._ping_gen = 0; self._ping_lock = threading.Lock()
        self._connectivity_manager = None; self._last_network_id = None
        self._ip_cache: Dict = {}; self._pending_ips = set()
        self._inflight_ips = set(); self._geo_running = False
        self._batch_lock = threading.Lock()
        self._cache      = ProxyCache()
        self._blacklist  = Blacklist()
        self._logger     = LocalLogger()
        self._stats      = ProxyStats(f"{DATA_DIR}/pm_stats.json")
        self._favorites  = FavoriteProxies(f"{DATA_DIR}/pm_favorites.json")
        self._history    = SwitchHistory(f"{DATA_DIR}/pm_history.json")
        self._prefetcher = Prefetcher(get_list=lambda: self.proxy_list, get_idx=lambda: self.current_index)
        self._updater    = PluginUpdater(self)
        self._orbot_tried = False   # пробовали ли уже Orbot в этой сессии

    # ─── логирование ──────────────────────────

    def log(self, msg: str):
        self._logger.write(msg)
        try: super().log(msg)
        except: pass

    # ─── настройки ────────────────────────────

    def create_settings(self):
        status    = self.get_setting("_status_line", "🔴 Неактивен")
        substatus = self.get_setting("_status_sub",  "")
        mode      = self.get_setting("switch_mode", SWITCH_AUTO)
        is_manual = (mode == SWITCH_MANUAL)
        proxy_items = [proxy_label(p) for p in self.proxy_list] if self.proxy_list else ["(нет)"]

        rows = [
            Header(text="━━━  PROXY MANAGER PRO v6  ━━━"),
            Text(text=status, subtext=substatus),
            Divider(),

            Header(text="Режим переключения"),
            Selector(key="switch_mode", text="Режим",
                     default=0 if mode == SWITCH_AUTO else 1,
                     items=["🤖 Авто (по пингу)", "✋ Ручной (выбор из пула)"],
                     on_change=self._on_mode_change),
        ]
        if is_manual and self.proxy_list:
            rows.append(Selector(key="manual_proxy_idx", text="Выбрать прокси",
                                 default=self.current_index, items=proxy_items,
                                 on_change=self._on_manual_proxy_change))
        rows += [
            Divider(),
            Header(text="Источники прокси"),
            Input(key="channels", text="Каналы (через запятую)", default=DEFAULT_CHANNELS,
                  subtext="username без @"),
            Switch(key="use_mtproto", text="MTProto", default=True),
            Switch(key="use_socks5",  text="SOCKS5",  default=True),

            Divider(),
            Header(text="Пинг / проверка"),
            Selector(key="ping_timeout_idx", text="Таймаут проверки", default=1,
                     items=[f"{x} с" for x in TIMEOUTS]),
            Selector(key="ping_concurrency_idx", text="Параллелизм", default=1,
                     items=[str(x) for x in CONCURRENCY_OPTS]),

            Header(text="Авто-переключение"),
            Selector(key="check_interval", text="Проверять каждые", default=2,
                     items=["10 сек","20 сек","30 сек","60 сек","120 сек"]),
            Selector(key="ping_threshold", text="Порог переключения", default=1,
                     items=["100 мс","150 мс","200 мс","300 мс","500 мс"]),
            Text(text=f"⚠️ Переключение после {SWITCH_CONFIRM_COUNT} раз подряд выше порога",
                 subtext="Защита от кратковременных скачков"),

            Divider(),
            Header(text="Отображение"),
            Switch(key="show_geo",   text="Флаги стран и провайдер", default=True),
            Switch(key="show_dpi",   text="Анти-DPI бейджи",          default=True),
            Switch(key="ping_color", text="Цвет по пингу",             default=True),
            Selector(key="geo_ttl_idx", text="Срок жизни гео-кэша", default=2,
                     items=[f"{x} дн" for x in GEO_TTL_DAYS]),

            Divider(),
            Header(text="Значки маскировки (можно заменить эмодзи)"),
            Input(key="badge_faketls_good", text="FakeTLS + CDN домен",    default="🛡️"),
            Input(key="badge_faketls",      text="FakeTLS",                 default="🔒"),
            Input(key="badge_secured",      text="random-padding",          default="➿"),
            Input(key="badge_plain",        text="plain MTProto",            default="⚠️"),
            Input(key="badge_socks",        text="SOCKS5",                  default="🧦"),

            Divider(),
            Header(text="Обновление базы прокси"),
            Selector(key="refresh_interval", text="Автообновление каждые", default=2,
                     items=["15 мин","30 мин","60 мин","2 часа","Выкл"]),

            Divider(),
            Header(text="Уведомления"),
            Switch(key="notify_switch",     text="При переключении прокси",        default=True),
            Switch(key="notify_network",    text="При смене сети",                  default=True),
            Switch(key="notify_refresh",    text="При обновлении базы",             default=False),
            Switch(key="show_notification", text="Постоянное Android-уведомление",  default=True),

            Header(text="Плагин"),
            Switch(key="auto_update", text="Авто-обновление при старте", default=True),

            Divider(),
            Header(text="Управление"),
            Text(text="🏁 Запустить гонку прокси",          accent=True, on_click=self._manual_reparse),
            Text(text="📊 Пинговать все прокси в списке",   accent=True, on_click=self._on_ping_all_btn),
            Text(text="🔄 Переподключиться сейчас",          accent=True, on_click=self._manual_reconnect),
            Text(text="🆕 Проверить обновление плагина",    accent=True, on_click=lambda v=None: self._updater.check_and_update(silent=False)),
            Text(text="📋 Экспортировать логи в файл",      accent=True, on_click=self._export_logs),
            Text(text="🗑 Очистить кэш и блэклист",         accent=True, on_click=self._clear_cache),

            Divider(),
            Header(text="Список прокси (инструменты)"),
            Text(text="📥 Импорт прокси",                   accent=True, on_click=self._open_import_menu),
            Text(text="📤 Экспорт прокси",                  accent=True, on_click=self._open_export_menu),
            Text(text="⚙️ Управление списком",              accent=True, on_click=self._open_manage_menu),

            Divider(),
            Header(text="Аналитика"),
            Text(text="📈 История переключений",             accent=True, on_click=self._show_history),
            Text(text="⭐ Управление избранными прокси",     accent=True, on_click=self._show_favorites_menu),

            Divider(),
            Header(text="Настройки плагина"),
            Text(text="📤 Экспорт настроек → Избранное", accent=True, on_click=self._export_plugin_settings),
            Text(text="📥 Импорт настроек из буфера",    accent=True, on_click=self._import_plugin_settings),

            Divider(),
            Header(text="🧅 Tor (Orbot) — резервный вариант"),
            Text(
                text="Используется только если все прокси мертвы",
                subtext="Требует установленный Orbot из Play Market",
            ),
            Switch(key="orbot_enabled", text="Включить Orbot как резерв", default=True),
            Text(text="🧅 Проверить Orbot сейчас", accent=True, on_click=self._check_orbot_btn),
            Text(text="📲 Открыть Orbot",          accent=True, on_click=lambda v=None: run_on_ui_thread(open_orbot)),
        ]
        return rows

    def _get_channels(self):
        raw = self.get_setting("channels", DEFAULT_CHANNELS)
        return [c.strip() for c in str(raw).split(",") if c.strip()]
    def _get_interval(self):
        idx = safe_int(self.get_setting("check_interval",2),2)
        return INTERVAL_OPTIONS[idx] if 0 <= idx < len(INTERVAL_OPTIONS) else 30
    def _get_threshold(self):
        idx = safe_int(self.get_setting("ping_threshold",1),1)
        return THRESHOLD_OPTIONS[idx] if 0 <= idx < len(THRESHOLD_OPTIONS) else 150.0
    def _get_refresh(self):
        idx = safe_int(self.get_setting("refresh_interval",2),2)
        mins = REFRESH_OPTIONS[idx] if 0 <= idx < len(REFRESH_OPTIONS) else 60
        return mins*60
    def _get_timeout(self):
        idx = safe_int(self.get_setting("ping_timeout_idx",1),1)
        return TIMEOUTS[idx] if 0 <= idx < len(TIMEOUTS) else 5
    def _is_manual(self): return self.get_setting("switch_mode",SWITCH_AUTO) == SWITCH_MANUAL
    def _use_mtproto(self): return bool(self.get_setting("use_mtproto",True))
    def _use_socks5(self): return bool(self.get_setting("use_socks5",True))
    def _notify_switch(self): return bool(self.get_setting("notify_switch",True))
    def _notify_network(self): return bool(self.get_setting("notify_network",True))
    def _filter_by_type(self, proxies):
        mt = self._use_mtproto(); s5 = self._use_socks5()
        return [p for p in proxies
                if (p.get("type")==PROXY_MTPROTO and mt) or (p.get("type")==PROXY_SOCKS5 and s5)]

    def _save_status(self):
        if self.proxy_list and self.active:
            p = self.proxy_list[self.current_index]
            tp = "🧅 Tor" if p.get("is_orbot") else ("MTProto" if p.get("type")==PROXY_MTPROTO else "SOCKS5")
            spd = p.get("speed_kbps",0)
            cls = _classify_proxy(type('X', (), {'secret': p.get('secret','')})())
            badge = self.get_setting(f"badge_{cls['badge_key']}", cls["badge"]) or cls["badge"]
            spd_str = f" • {spd:.0f} Кбит/с" if spd > 0 else ""
            mode = "✋ Ручной" if self._is_manual() else "🤖 Авто"
            self.set_setting("_status_line",
                f"🟢 {badge} [{tp}] {p['server']}:{p['port']} • {p.get('ping',0):.0f} мс{spd_str}")
            self.set_setting("_status_sub",
                f"Режим: {mode} • Пул: {len(self.proxy_list)} • Блэклист: {self._blacklist.banned_count()}")
        else:
            self.set_setting("_status_line","🔴 Неактивен")
            self.set_setting("_status_sub", f"В базе: {len(self.proxy_list)}")

    def _on_mode_change(self, idx):
        mode = SWITCH_MANUAL if idx == 1 else SWITCH_AUTO
        self.set_setting("switch_mode", mode); self._bad_ping_streak = 0
        label = "✋ Ручной режим — авто отключено" if mode==SWITCH_MANUAL else "🤖 Авто-режим включён"
        run_on_ui_thread(lambda: BulletinHelper.show_info(label))
        self._save_status()

    def _on_manual_proxy_change(self, idx):
        if not self.proxy_list or idx >= len(self.proxy_list): return
        self.current_index = idx; p = self.proxy_list[idx]
        self._apply_proxy(p); self._save_status()
        run_on_ui_thread(lambda: BulletinHelper.show_success(f"✋ {proxy_label(p)}"))

    def _manual_reconnect(self, view=None):
        if not self.proxy_list:
            run_on_ui_thread(lambda: BulletinHelper.show_error("❌ Нет прокси")); return
        p = self.proxy_list[self.current_index]
        self._apply_proxy(p)
        run_on_ui_thread(lambda: BulletinHelper.show_success(f"🔄 {p['server']}:{p['port']}"))

    def _manual_reparse(self, view=None):
        if self.loading:
            run_on_ui_thread(lambda: BulletinHelper.show_info("⏳ Уже выполняется...")); return
        self._orbot_tried = False  # сбрасываем при ручном перезапуске
        run_on_ui_thread(lambda: BulletinHelper.show_info("🏁 Запускаю гонку..."))
        threading.Thread(target=self._startup, daemon=True, name="pm-manual").start()

    def _on_ping_all_btn(self, view=None):
        self._on_ping_all()

    def _export_logs(self, view=None):
        try:
            path = f"{DATA_DIR}/pm_logs_{int(time.time())}.txt"
            content = self._logger.export()
            with open(path, "w") as f:
                f.write(f"Proxy Manager Pro {PLUGIN_VERSION}\n")
                f.write(f"Дата: {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}\n")
                f.write(f"Прокси в пуле: {len(self.proxy_list)}\n")
                f.write("─"*50+"\n"+content)
            run_on_ui_thread(lambda: BulletinHelper.show_success(f"📋 Логи: {path}"))
        except Exception as e:
            run_on_ui_thread(lambda: BulletinHelper.show_error(f"❌ {e}"))

    def _clear_cache(self, view=None):
        self._cache.clear(); self._blacklist.clear()
        run_on_ui_thread(lambda: BulletinHelper.show_success("🗑 Очищено"))

    # ─── lifecycle ────────────────────────────

    def on_plugin_load(self):
        with self.lock: self.unloading=False; self.active=False; self.loading=False
        self._load_ip_cache(); self._hook_proxy_list(); self._hook_proxy_cells()
        self._add_menu()
        self.log(f"=== Proxy Manager Pro {PLUGIN_VERSION} запущен ===")
        run_on_ui_thread(lambda: BulletinHelper.show_info("🏁 Proxy Manager Pro v6: запускаюсь..."))
        threading.Thread(target=self._startup, daemon=True, name="pm-startup").start()
        if self.get_setting("auto_update",True): self._updater.check_and_update(silent=True)

    def on_plugin_unload(self):
        with self.lock: self.unloading=True; self.active=False
        self._prefetcher.stop(); self._unhook_all()
        try: self.remove_menu_item("pm_toggle")
        except: pass
        run_on_ui_thread(self._disable_proxy_globally)
        run_on_ui_thread(_hide_status_notification)
        self.log("=== Proxy Manager выгружен ===")

    def on_app_event(self, et):
        if self.unloading or self.loading or not self.active: return
        if et in (AppEvent.RESUME, AppEvent.START):
            threading.Thread(target=self._check_current, daemon=True).start()

    # ─── меню ────────────────────────────────

    def _add_menu(self):
        try: self.remove_menu_item("pm_toggle")
        except: pass
        try:
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.DRAWER_MENU, item_id="pm_toggle",
                text="⏸ Выключить Proxy Manager" if self.active else "🛡 Proxy Manager Pro",
                icon="msg_block" if self.active else "msg_secret",
                on_click=self._menu_click,
            ))
        except: pass

    def _menu_click(self, ctx):
        if self.active: self._disable()
        else: threading.Thread(target=self._startup, daemon=True).start()

    def _add_action_buttons(self, fragment):
        try:
            ab = get_private_field(fragment, "actionBar")
            if ab is None: return
            menu = ab.createMenu(); iw = AndroidUtilities.dp(40); plg = self
            if menu.getItem(MENU_EXPORT_ID) is None:
                it = menu.addItemWithWidth(MENU_EXPORT_ID, R_tg.drawable.msg_share, iw, "Экспорт")
                it.setOnClickListener(OnClickListener(lambda v, f=fragment: plg._open_export_menu(f)))
            if menu.getItem(MENU_IMPORT_ID) is None:
                it = menu.addItemWithWidth(MENU_IMPORT_ID, R_tg.drawable.msg_download, iw, "Импорт")
                it.setOnClickListener(OnClickListener(lambda v, f=fragment: plg._open_import_menu(f)))
            if menu.getItem(MENU_MANAGE_ID) is None:
                it = menu.addItemWithWidth(MENU_MANAGE_ID, R_tg.drawable.msg_settings, iw, "Действия")
                it.setOnClickListener(OnClickListener(lambda v, f=fragment: plg._open_manage_menu(f)))
            if menu.getItem(MENU_SORT_ID) is None:
                it = menu.addItemWithWidth(MENU_SORT_ID, R_tg.drawable.msg_list, iw, "По пингу")
                it.setOnClickListener(OnClickListener(lambda v, f=fragment: plg._sort_by_ping()))
            if menu.getItem(MENU_PING_ALL_ID) is None:
                it = menu.addItemWithWidth(MENU_PING_ALL_ID, R_tg.drawable.msg_recent, iw, "Пинг все")
                it.setOnClickListener(OnClickListener(lambda v, f=fragment: plg._on_ping_all()))
            if menu.getItem(MENU_RACE_ID) is None:
                it = menu.addItemWithWidth(MENU_RACE_ID, R_tg.drawable.msg_secret, iw, "Гонка")
                it.setOnClickListener(OnClickListener(lambda v, f=fragment: plg._manual_reparse()))
        except Exception as e: log(f"pm: action buttons {e}")

    # ─── хуки proxy list ─────────────────────

    def _hook_proxy_list(self):
        try:
            act_cls = find_class("org.telegram.ui.ProxyListActivity")
            if act_cls is None: return
            jc = act_cls.getClass()
            ctx_cls = find_class("android.content.Context")
            try:
                m = jc.getDeclaredMethod("checkProxyList"); m.setAccessible(True)
                self._all_hooks.append(self.hook_method(m, _CheckProxyListHook(self)))
            except: pass
            try:
                m = jc.getDeclaredMethod("createView", ctx_cls); m.setAccessible(True)
                self._all_hooks.append(self.hook_method(m, _CreateViewHook(self)))
            except: pass
        except Exception as e: log(f"pm: hook list {e}")

    def _hook_proxy_cells(self):
        try:
            cell_cls = find_class("org.telegram.ui.ProxyListActivity$TextDetailProxyCell")
            if cell_cls is None: return
            cc = cell_cls.getClass()
            try:
                m = cc.getDeclaredMethod("updateStatus"); m.setAccessible(True)
                self._all_hooks.append(self.hook_method(m, _CellUpdateStatusHook(self)))
            except: pass
            pi_cls = find_class("org.telegram.messenger.SharedConfig$ProxyInfo")
            if pi_cls:
                try:
                    m = cc.getDeclaredMethod("setProxy", pi_cls); m.setAccessible(True)
                    self._all_hooks.append(self.hook_method(m, _CellSetProxyHook(self)))
                except: pass
        except Exception as e: log(f"pm: hook cells {e}")

    # ─── запуск / гонка ──────────────────────

    def _startup(self):
        with self.lock:
            if self.loading: return
            self.loading = True
        try:
            # Пробуем кэш с быстрой предпроверкой
            cached = self._blacklist.filter(self._cache.load(max_age=CACHE_MAX_AGE))
            cached = self._filter_by_type(cached)

            if cached:
                self.log(f"Кэш: {len(cached)} прокси — быстро чекаю топ-{CACHE_RECHECK_N}...")
                run_on_ui_thread(lambda: BulletinHelper.show_info(
                    f"⚡ Проверяю кэш ({len(cached)} прокси)..."))

                # Быстро чекаем топ-N из кэша параллельно
                top = cached[:CACHE_RECHECK_N]
                alive = []
                lock = threading.Lock()
                def quick_check(p):
                    ping = check_proxy_real(p, timeout=3)  # короткий таймаут
                    if ping < 9999.0:
                        p["ping"] = ping
                        with lock: alive.append(p)
                with ThreadPoolExecutor(max_workers=CACHE_RECHECK_N) as ex:
                    list(ex.map(quick_check, top))

                if alive:
                    # Есть живые в кэше — запускаем гонку из всего кэша
                    alive.sort(key=proxy_score)
                    self.log(f"Кэш: {len(alive)}/{len(top)} живых — запускаю гонку")
                    # Ставим живых вперёд
                    dead_keys = {(p["server"],p["port"]) for p in top if p not in alive}
                    rest = [p for p in cached if (p["server"],p["port"]) not in dead_keys]
                    self._run_race(alive + rest, then_fetch=True)
                    return
                else:
                    # Все топ-N мертвы — кэш устарел, парсим заново
                    self.log(f"Кэш устарел ({len(top)} проверено, все мертвы) — парсю каналы")
                    self._cache.clear()
                    run_on_ui_thread(lambda: BulletinHelper.show_info(
                        "⚠️ Кэш устарел — ищу свежие прокси..."))

            # Полный парсинг каналов + резервные
            self.log("Парсю каналы...")
            run_on_ui_thread(lambda: BulletinHelper.show_info("🔍 Парсю каналы..."))
            raw = self._fetch_raw_proxies()
            seen = {(p["server"],p["port"]) for p in raw}
            for p in HARDCODED_FALLBACK:
                if (p["server"],p["port"]) not in seen:
                    raw.append(p); seen.add((p["server"],p["port"]))
            raw = self._blacklist.filter(self._filter_by_type(raw))

            # Приоритизируем FakeTLS с CDN доменом (живут дольше)
            raw = self._prioritize_by_type(raw)

            self.log(f"Гонка: {len(raw)} прокси")
            run_on_ui_thread(lambda n=len(raw): BulletinHelper.show_info(
                f"🏁 Гонка: {n} прокси..."))
            self._run_race(raw, then_fetch=False)
        finally:
            with self.lock: self.loading = False

    def _run_race(self, proxies, then_fetch=False):
        winner_ev = threading.Event(); timeout = self._get_timeout()

        def on_winner(p):
            self._apply_proxy(p); self._install_hooks()
            with self.lock: self.active = True
            run_on_ui_thread(self._add_menu)
            self._prefetcher.start(); self._start_monitor()
            self._start_network_monitor(); self._start_refresh_timer()
            tp = "🧅 Tor" if p.get("is_orbot") else ("MTProto" if p.get("type")==PROXY_MTPROTO else "SOCKS5")
            cls = _classify_proxy(type('X',(),{'secret':p.get('secret','')})())
            badge = self.get_setting(f"badge_{cls['badge_key']}", cls["badge"]) or cls["badge"]
            self.log(f"🏆 [{tp}] {badge} {p['server']} {p.get('ping',0):.0f}мс")
            run_on_ui_thread(lambda: BulletinHelper.show_success(
                f"🏆 {badge} [{tp}] {p['server']} • {p.get('ping',0):.0f} мс"))
            winner_ev.set()

        def on_done(results):
            if not results:
                if not winner_ev.is_set():
                    self.log("Гонка: нет рабочих")
                    run_on_ui_thread(lambda: BulletinHelper.show_error("❌ Нет рабочих прокси"))
                return
            self.proxy_list = results; self.current_index = 0
            self._save_status()
            # Кэшируем только проверенные (у которых есть реальный пинг)
            verified = [p for p in results if p.get("ping", 0) > 0]
            self._cache.save(verified)
            self.log(f"Кэш: сохранено {len(verified)} проверенных прокси")
            mt = sum(1 for p in results if p.get("type")==PROXY_MTPROTO)
            s5 = len(results)-mt
            self.log(f"Гонка завершена: {len(results)} ({mt} MTProto, {s5} SOCKS5)")
            run_on_ui_thread(lambda: BulletinHelper.show_success(
                f"✅ {len(results)} прокси: {mt} MTProto + {s5} SOCKS5"))
            if then_fetch:
                threading.Thread(target=self._background_refresh, daemon=True, name="pm-bg").start()

        # Избранные прокси идут первыми в гонке
        proxies = self._favorites.prioritize(proxies)
        ProxyRace(proxies, on_winner=on_winner, on_done=on_done, timeout=timeout).start()
        winner_ev.wait(timeout=15)
        if not winner_ev.is_set():
            self.log("Гонка: таймаут 15 сек — пробую Orbot...")
            run_on_ui_thread(lambda: BulletinHelper.show_error("❌ Нет прокси — пробую Tor (Orbot)..."))
            threading.Thread(target=self._try_orbot_fallback, daemon=True, name="pm-orbot").start()

    def _try_orbot_fallback(self):
        """
        Последний резерв: если все прокси мертвы — пробуем Tor через Orbot.
        Работает только если Orbot установлен на устройстве.
        """
        if self._orbot_tried:
            run_on_ui_thread(lambda: BulletinHelper.show_error(
                "❌ Нет рабочих прокси и Orbot не помог. Проверь интернет."))
            return

        self._orbot_tried = True

        # Проверяем установлен ли Orbot
        # Проверяем включён ли Orbot в настройках
        if not self.get_setting("orbot_enabled", True):
            self.log("Orbot отключён в настройках")
            run_on_ui_thread(lambda: BulletinHelper.show_error(
                "❌ Нет рабочих прокси. Включи Orbot в настройках плагина как резерв."))
            return

        if not is_orbot_installed():
            self.log("Orbot не установлен")
            run_on_ui_thread(lambda: BulletinHelper.show_error(
                "❌ Установи Orbot (Tor) из Play Market как резервный вариант"))
            return

        self.log("Orbot найден, проверяю...")
        run_on_ui_thread(lambda: BulletinHelper.show_info("🧅 Пробую Tor через Orbot..."))

        # Если Orbot не запущен — пытаемся запустить
        if not is_orbot_running():
            self.log("Orbot не запущен, запускаю...")
            run_on_ui_thread(lambda: BulletinHelper.show_info(
                "🧅 Запускаю Orbot... подождите 30 сек"))
            start_orbot()
            # Ждём пока Tor поднимется (обычно 15-30 сек)
            for _ in range(30):
                time.sleep(1)
                if is_orbot_running():
                    self.log("Orbot запустился")
                    break
            else:
                self.log("Orbot не запустился за 30 сек")
                run_on_ui_thread(lambda: BulletinHelper.show_error(
                    "❌ Orbot не запустился. Открой Orbot вручную и нажми Start."))
                run_on_ui_thread(open_orbot)
                return

        # Проверяем работает ли Tor
        ping = check_orbot_proxy(timeout=10)
        if ping >= 9999.0:
            self.log("Orbot запущен но SOCKS5 не отвечает")
            run_on_ui_thread(lambda: BulletinHelper.show_error(
                "❌ Orbot запущен, но Tor не отвечает. Подожди и попробуй снова."))
            return

        # Применяем Orbot как прокси
        orbot_proxy = dict(ORBOT_PROXY)
        orbot_proxy["ping"] = ping
        self.proxy_list = [orbot_proxy]
        self.current_index = 0
        self._apply_proxy(orbot_proxy)
        self._install_hooks()
        with self.lock: self.active = True
        run_on_ui_thread(self._add_menu)
        self._start_monitor()
        self._start_network_monitor()
        self._save_status()
        self.log(f"✅ Подключено через Tor/Orbot • {ping:.0f} мс")
        run_on_ui_thread(lambda: BulletinHelper.show_success(
            f"🧅 Tor • {ping:.0f} мс — скорость ниже обычного, это нормально"))


    def _background_refresh(self):
        raw = self._fetch_raw_proxies()
        seen = {(p["server"],p["port"]) for p in raw}
        for p in HARDCODED_FALLBACK:
            if (p["server"],p["port"]) not in seen: raw.append(p); seen.add((p["server"],p["port"]))
        raw = self._blacklist.filter(self._filter_by_type(raw))
        if not raw: return
        results, lock = [], threading.Lock(); timeout = self._get_timeout()
        def chk(p):
            if tcp_alive(p["server"],p["port"]) >= 9999.0: return
            ping = check_proxy_real(p, timeout)
            if ping < 9999.0:
                p["ping"] = ping
                with lock: results.append(p)
        with ThreadPoolExecutor(max_workers=RACE_WORKERS) as ex: list(ex.map(chk, raw))
        if results:
            results.sort(key=proxy_score)
            self.proxy_list = results; self._save_status(); self._cache.save(results)
            self.log(f"Фоновое обновление: {len(results)}")
            if self.get_setting("notify_refresh",False):
                run_on_ui_thread(lambda: BulletinHelper.show_info(f"🔄 База: {len(results)} прокси"))

    def _disable(self):
        with self.lock: self.active = False
        self._prefetcher.stop(); self._unhook_all()
        self.set_setting("_status_line","🔴 Неактивен"); self.set_setting("_status_sub",f"В базе: {len(self.proxy_list)}")
        run_on_ui_thread(self._disable_proxy_globally)
        run_on_ui_thread(lambda: BulletinHelper.show_info("Proxy Manager отключён"))
        run_on_ui_thread(_hide_status_notification)
        run_on_ui_thread(self._add_menu); self.log("Отключён пользователем")

    # ─── парсинг ─────────────────────────────

    def _fetch_and_check_stream(self, on_first: Callable, on_all: Callable):
        """
        Параллельный парсинг + проверка: каналы парсятся одновременно,
        каждый найденный прокси сразу уходит на проверку.
        on_first(proxy) — первый рабочий, on_all(results) — все готово.
        """
        channels = self._get_channels()
        timeout  = self._get_timeout()
        results  = []
        lock     = threading.Lock()
        first_ev = threading.Event()

        def process_proxy(p):
            if tcp_alive(p["server"], p["port"]) >= 9999.0: return
            ping = check_proxy_real(p, timeout)
            if ping >= 9999.0: return
            p["ping"] = ping
            with lock:
                results.append(p)
                is_first = not first_ev.is_set()
            if is_first:
                first_ev.set()
                on_first(p)
            spd = speed_test(p)
            if spd > 0: p["speed_kbps"] = spd

        def parse_and_submit(username):
            # Парсим канал
            proxies = fetch_from_web(username)
            # Сразу отправляем каждый на проверку
            with ThreadPoolExecutor(max_workers=5) as ex:
                list(ex.map(process_proxy, proxies))

        def parse_api_and_submit(username):
            try:
                peer = self._resolve_peer(username)
                if peer is None: return
                req = TLRPC.TL_messages_getHistory()
                req.peer = peer
                req.limit = 50
                req.offset_id = req.offset_date = req.add_offset = req.max_id = req.min_id = req.hash = 0
                h = [None]; ev = threading.Event()
                def cb(r, e, h=h, ev=ev): h[0]=r; ev.set()
                from client_utils import send_request, RequestCallback
                send_request(req, RequestCallback(cb)); ev.wait(timeout=6)
                msgs = h[0]
                if msgs and hasattr(msgs, "messages"):
                    proxies = []
                    for msg in msgs.messages: proxies.extend(extract_from_message(msg))
                    with ThreadPoolExecutor(max_workers=5) as ex:
                        list(ex.map(process_proxy, proxies))
            except Exception as e: self.log(f"API stream {username}: {e}")

        def fetch_github_and_submit(url):
            proxies = []
            try:
                ctx = ssl.create_default_context()
                req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
                with urllib.request.urlopen(req, timeout=WEB_TIMEOUT, context=ctx) as r:
                    proxies = parse_all_proxies(r.read().decode("utf-8", errors="ignore"))
            except: pass
            with ThreadPoolExecutor(max_workers=5) as ex:
                list(ex.map(process_proxy, proxies))

        # Запускаем всё параллельно
        tasks = (
            [lambda u=u: parse_api_and_submit(u) for u in channels] +
            [lambda u=u: parse_and_submit(u) for u in channels] +
            [lambda url=url: fetch_github_and_submit(url) for url in GITHUB_PROXY_SOURCES]
        )
        with ThreadPoolExecutor(max_workers=20) as ex:
            list(ex.map(lambda f: f(), tasks))

        # Резервные прокси если совсем ничего
        if not results:
            with ThreadPoolExecutor(max_workers=RACE_WORKERS) as ex:
                list(ex.map(process_proxy, HARDCODED_FALLBACK))

        results.sort(key=proxy_score)
        on_all(results)


    def _fetch_raw_proxies(self):
        raw, channels = [], self._get_channels()
        for username in channels:
            try:
                peer = self._resolve_peer(username)
                if peer is None: continue
                req = TLRPC.TL_messages_getHistory()
                req.peer = peer
                req.limit = 50; req.offset_id = req.offset_date = req.add_offset = req.max_id = req.min_id = req.hash = 0
                h = [None]; ev = threading.Event()
                def cb(r, e, h=h, ev=ev): h[0]=r; ev.set()
                from client_utils import send_request, RequestCallback
                send_request(req, RequestCallback(cb)); ev.wait(timeout=6)
                msgs = h[0]
                if msgs and hasattr(msgs,"messages"):
                    for msg in msgs.messages: raw.extend(extract_from_message(msg))
            except Exception as e: self.log(f"API {username}: {e}")
        with ThreadPoolExecutor(max_workers=10) as ex:
            for r in ex.map(fetch_from_web, channels): raw.extend(r)
        seen, unique = set(), []
        for p in raw:
            k = (p["server"],p["port"],p.get("type"))
            if k not in seen: seen.add(k); unique.append(p)
        # Парсим GitHub источники (обновляются каждые 4-12 часов)
        github_results = []
        def fetch_github(url):
            try:
                ctx = ssl.create_default_context()
                req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
                with urllib.request.urlopen(req, timeout=WEB_TIMEOUT, context=ctx) as r:
                    return parse_all_proxies(r.read().decode("utf-8", errors="ignore"))
            except Exception as e:
                self.log(f"GitHub {url[:50]}: {e}")
                return []

        with ThreadPoolExecutor(max_workers=5) as ex:
            for r in ex.map(fetch_github, GITHUB_PROXY_SOURCES):
                github_results.extend(r)
        self.log(f"GitHub источники: {len(github_results)} прокси")

        # Объединяем всё
        all_raw = raw + github_results
        seen, unique = set(), []
        for p in all_raw:
            k = (p["server"], p["port"], p.get("type"))
            if k not in seen:
                seen.add(k)
                unique.append(p)

        self.log(f"Собрано итого: {len(unique)} (каналы + GitHub)")
        return unique

    def _resolve_peer(self, username):
        try:
            ctrl = MessagesController.getInstance(UserConfig.selectedAccount)
            chat = ctrl.getUserOrChat(username)
            return ctrl.getInputPeer(chat) if chat else None
        except: return None

    # ─── пинг всего списка (как в Th3ProxyTools) ──

    def _on_ping_all(self, fragment=None):
        with self._ping_lock:
            busy = self._ping_busy
            if not busy: self._ping_busy = True
        if busy:
            run_on_ui_thread(lambda: BulletinHelper.show_info("⏳ Пинг уже идёт...")); return
        self._ping_gen += 1; gen = self._ping_gen; timeout = self._get_timeout()
        ci = safe_int(self.get_setting("ping_concurrency_idx",1),1)
        concurrency = CONCURRENCY_OPTS[ci] if 0 <= ci < len(CONCURRENCY_OPTS) else 16

        def start():
            try:
                SharedConfig.loadProxyList(); proxies = _jlist_to_py(SharedConfig.proxyList)
            except Exception as e: log(f"pm: load list {e}"); proxies = []
            if not proxies:
                run_on_ui_thread(lambda: BulletinHelper.show_info("Список прокси пуст"))
                with self._ping_lock: self._ping_busy = False; return
            total = len(proxies)
            run_on_ui_thread(lambda: BulletinHelper.show_info(f"📊 Пингую {total} прокси..."))
            ok = [0]; dead = [0]; done = [0]; lock = threading.Lock()

            def ping_one(p):
                if self._ping_gen != gen: return
                host = str(getattr(p,"address","") or "").strip()
                port = int(getattr(p,"port",0) or 0)
                secret = str(getattr(p,"secret","") or "")
                user = str(getattr(p,"username","") or "")
                pwd = str(getattr(p,"password","") or "")
                proxy_dict = {"server":host,"port":port,"secret":secret,"user":user,"pass":pwd,
                              "type": PROXY_SOCKS5 if not secret else PROXY_MTPROTO}
                ms = check_proxy_real(proxy_dict, timeout)

                def update():
                    try:
                        p.checking = False
                        p.availableCheckTime = SystemClock.elapsedRealtime()
                        if ms < 9999.0:
                            p.available = True; p.ping = int(ms); ok[0] += 1
                        else:
                            p.available = False; p.ping = 0; dead[0] += 1
                        done[0] += 1
                        _post_proxy_check_done(p)
                        if done[0] >= total:
                            try: SharedConfig.saveProxyList()
                            except: pass
                            self._notify_proxy_settings_changed()
                            with self._ping_lock: self._ping_busy = False
                            run_on_ui_thread(lambda: BulletinHelper.show_success(
                                f"✅ Пинг завершён: {ok[0]} работают, {dead[0]} мертвы"))
                    except Exception as e: log(f"pm: ping update {e}")
                run_on_ui_thread(update)

            with ThreadPoolExecutor(max_workers=concurrency) as ex: list(ex.map(ping_one, proxies))

        threading.Thread(target=start, daemon=True, name="pm-ping-all").start()

    def _notify_proxy_settings_changed(self):
        try: NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.proxySettingsChanged)
        except: pass

    # ─── применение прокси ───────────────────

    def _apply_proxy(self, proxy: dict):
        srv=proxy["server"]; prt=proxy["port"]; sec=proxy.get("secret","")
        user=proxy.get("user",""); pwd=proxy.get("pass","")
        is_socks = proxy.get("type")==PROXY_SOCKS5
        def do():
            try:
                pi = None
                try:
                    PC = find_class("org.telegram.messenger.SharedConfig$ProxyInfo")
                    if PC:
                        pi = PC.getConstructor(str,int,str,str,str).newInstance(
                            srv, prt, user if is_socks else "", pwd if is_socks else "", "" if is_socks else sec)
                except Exception as e: self.log(f"ProxyInfo: {e}")
                if pi is not None:
                    try:
                        if not hasattr(SharedConfig,"proxyList") or SharedConfig.proxyList is None:
                            from java.util import ArrayList; SharedConfig.proxyList = ArrayList()
                        SharedConfig.proxyList.clear(); SharedConfig.proxyList.add(pi)
                        SharedConfig.currentProxy = pi; self.proxy_info = pi
                    except: pass
                try:
                    ed = MessagesController.getGlobalMainSettings().edit()
                    ed.putBoolean("proxy_enabled",True); ed.putString("proxy_ip",srv)
                    ed.putInt("proxy_port",prt); ed.putString("proxy_user",user)
                    ed.putString("proxy_pass",pwd); ed.putString("proxy_secret",sec); ed.commit()
                except: pass
                try: ConnectionsManager.setProxySettings(True,srv,prt,user,pwd,sec)
                except:
                    try: ConnectionsManager.getInstance(UserConfig.selectedAccount).setProxySettings(True,srv,prt,user,pwd,sec)
                    except: pass
                try: NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.proxySettingsChanged)
                except: pass
                self._blacklist.reset(proxy)
                self.log(f"Применён: {srv}:{prt}")
            except Exception as e: self.log(f"_apply_proxy: {e}")
        run_on_ui_thread(do)

    def restore_proxy(self):
        with self.lock:
            if self.unloading or not self.active or not self.proxy_list: return
        self._apply_proxy(self.proxy_list[self.current_index])

    def _disable_proxy_globally(self):
        try: ConnectionsManager.setProxySettings(False,"",0,"","","")
        except:
            try: ConnectionsManager.getInstance(UserConfig.selectedAccount).setProxySettings(False,"",0,"","","")
            except: pass
        try: SharedConfig.proxyEnabled=False; SharedConfig.currentProxy=None
        except: pass
        try: NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.proxySettingsChanged)
        except: pass

    # ─── переключение ────────────────────────

    def _prioritize_by_type(self, proxies: List[Dict]) -> List[Dict]:
        """
        Приоритизация:
        1. FakeTLS с CDN доменом (🛡️) — живут дольше всего
        2. FakeTLS обычный (🔒)
        3. MTProto random-pad (➿)
        4. Избранные (вне зависимости от типа)
        5. Остальные
        """
        def priority(p):
            b = _secret_to_bytes(p.get("secret",""))
            if b and b[0] == 0xEE and len(b) >= 17:
                dom = b[17:].decode("utf-8","replace").strip()
                if any(dom == d or dom.endswith("."+d) for d in _GOOD_FRONTS):
                    return 0  # FakeTLS + CDN — лучший
                return 1      # FakeTLS обычный
            if b and b[0] == 0xDD:
                return 2      # random-pad
            return 3          # остальные

        # Избранные идут первыми независимо от типа
        favs = [p for p in proxies if self._favorites.is_favorite(p)]
        rest = [p for p in proxies if not self._favorites.is_favorite(p)]
        rest.sort(key=priority)
        return favs + rest

    def _weighted_next(self) -> Optional[Dict]:
        """
        Weighted rotation: прокси с высоким uptime получает больше шансов.
        Возвращает следующий прокси или None если список пуст.
        """
        candidates = [
            (i, p) for i, p in enumerate(self.proxy_list)
            if i != self.current_index and not self._blacklist.is_banned(p)
        ]
        if not candidates: return None

        # Считаем веса на основе uptime из статистики
        weights = []
        for i, p in candidates:
            uptime = self._stats.uptime(p)
            uses   = self._stats.uses(p)
            # Новые прокси (uses==0) получают средний вес 50
            w = max(1, uptime if uses > 0 else 50)
            weights.append((i, p, w))

        # Weighted random выбор
        import random
        total = sum(w for _, _, w in weights)
        r = random.uniform(0, total)
        cumulative = 0
        for i, p, w in weights:
            cumulative += w
            if r <= cumulative:
                return (i, p)
        return weights[-1][:2]  # fallback на последний


    def _switch_next(self, reason=""):
        if self._is_manual(): self.log(f"Ручной режим — пропуск ({reason})"); return
        good = self._blacklist.filter(self.proxy_list)
        if not good: threading.Thread(target=self._startup, daemon=True).start(); return

        # Weighted rotation — учитываем uptime из статистики
        result = self._weighted_next()
        if result is None:
            threading.Thread(target=self._startup, daemon=True).start(); return

        new_idx, p = result
        self.current_index = new_idx
        self._apply_proxy(p); self._save_status(); self._bad_ping_streak = 0
        self.log(f"Переключение [{reason}] → {p['server']} (uptime {self._stats.uptime(p):.0f}%)")
        self._history.record(p, reason, p.get("ping", 0))
        self._stats.record_connect(p, p.get("ping", 0))
        if self._notify_switch():
            tp = "🧅 Tor" if p.get("is_orbot") else ("SOCKS5" if p.get("type")==PROXY_SOCKS5 else "MTProto")
            lbl = f" ({reason})" if reason else ""
            run_on_ui_thread(lambda: BulletinHelper.show_info(
                f"🔄 [{tp}] {p['server']} • {p.get('ping',0):.0f} мс{lbl}"))
        # Обновляем Android уведомление
        if self.get_setting("show_notification", True):
            cls = _classify_proxy(type('X',(),{'secret':p.get('secret','')})())
            badge = self.get_setting(f"badge_{cls['badge_key']}", cls["badge"]) or cls["badge"]
            run_on_ui_thread(lambda: _show_status_notification(
                f"🔄 Proxy Manager • {p.get('ping',0):.0f} мс",
                f"{badge} {p['server']}:{p['port']}"
            ))

    def _find_better_proxy(self, current_ping: float):
        if self._is_manual(): return
        if len(self.proxy_list) <= 1: return
        candidates = [(i,p) for i,p in enumerate(self.proxy_list)
                      if i != self.current_index and not self._blacklist.is_banned(p)]
        if not candidates: return
        results, lock = [], threading.Lock(); timeout = self._get_timeout()
        def chk(ip):
            i, p = ip
            if p.get("prefetched") and p.get("ping",9999) < 9999:
                with lock: results.append((i,p,p["ping"])); return
            ping = check_proxy_real(p, timeout)
            if ping < 9999.0:
                p["ping"] = ping
                with lock: results.append((i,p,ping))
        with ThreadPoolExecutor(max_workers=min(10,len(candidates))) as ex: list(ex.map(chk,candidates))
        if not results: return
        results.sort(key=lambda x: x[2])
        bi,bp,bping = results[0]
        if bping < current_ping*0.8:
            self.log(f"Лучший: {bp['server']} {bping:.0f} vs {current_ping:.0f}")
            self.current_index = bi; self._apply_proxy(bp); self._save_status(); self._bad_ping_streak = 0
            if self._notify_switch():
                tp = "SOCKS5" if bp.get("type")==PROXY_SOCKS5 else "MTProto"
                run_on_ui_thread(lambda: BulletinHelper.show_info(f"⚡ [{tp}] {bp['server']} • {bping:.0f} мс"))

    def _on_connection_stuck(self):
        now = time.monotonic()
        if now - self._stuck_cooldown < 30: return
        self._stuck_cooldown = now
        if not self.active or self.unloading or not self.proxy_list or self._is_manual(): return
        p = self.proxy_list[self.current_index]
        self.log(f"Зависание на {p['server']}")
        self._blacklist.strike(p); self._switch_next(reason="зависание")

    # ─── мониторинг ──────────────────────────

    def _check_current(self):
        if not self.proxy_list: return
        p = self.proxy_list[self.current_index]; threshold = self._get_threshold()
        if tcp_alive(p["server"],p["port"]) >= 9999.0:
            self.log(f"Упал: {p['server']}")
            self._blacklist.strike(p); self._bad_ping_streak = 0
            self._stats.record_failure(p)
            self._switch_next(reason="упал"); return
        ping = check_proxy_real(p, self._get_timeout())
        p["ping"] = ping
        self.log(f"Пинг {p['server']}: {ping:.0f}мс (порог {threshold:.0f}, streak {self._bad_ping_streak})")
        if ping > threshold:
            self._bad_ping_streak += 1
            if self._bad_ping_streak >= SWITCH_CONFIRM_COUNT:
                self._bad_ping_streak = 0; self._find_better_proxy(current_ping=ping)
        else:
            if self._bad_ping_streak > 0: self.log("Пинг вернулся в норму")
            self._bad_ping_streak = 0; self._save_status()

    def _start_monitor(self):
        if self._monitor_running: return
        self._monitor_running = True
        def loop():
            try:
                while self.active and not self.unloading:
                    time.sleep(self._get_interval())
                    if not self.active or self.unloading: break
                    self._check_current()
            finally: self._monitor_running = False
        threading.Thread(target=loop, daemon=True, name="pm-monitor").start()

    def _start_refresh_timer(self):
        if self._refresh_running: return
        interval = self._get_refresh()
        if interval == 0: return
        self._refresh_running = True
        def loop():
            try:
                while self.active and not self.unloading:
                    time.sleep(interval)
                    if not self.active or self.unloading: break
                    self._background_refresh()
            finally: self._refresh_running = False
        threading.Thread(target=loop, daemon=True, name="pm-refresh").start()

    def _start_network_monitor(self):
        if self._network_running: return
        try:
            from android.content import Context
            self._connectivity_manager = ApplicationLoader.applicationContext.getSystemService(Context.CONNECTIVITY_SERVICE)
            self._last_network_id = self._get_net_id()
        except: return
        self._network_running = True
        def loop():
            try:
                while self.active and not self.unloading:
                    time.sleep(NETWORK_POLL)
                    if not self.active or self.unloading: break
                    cur = self._get_net_id()
                    if self._last_network_id and cur and cur != self._last_network_id:
                        self._last_network_id = cur; self._schedule_reconnect()
                    elif cur: self._last_network_id = cur
            finally: self._network_running = False
        threading.Thread(target=loop, daemon=True, name="pm-netmon").start()

    def _get_net_id(self):
        try:
            n = self._connectivity_manager.getActiveNetwork()
            return n.toString() if n else None
        except: return None

    def _schedule_reconnect(self):
        with self.lock:
            if self._reconnect_pending or self.loading: return
            self._reconnect_pending = True
        if self._notify_network(): run_on_ui_thread(lambda: BulletinHelper.show_info("🔄 Сеть изменилась..."))
        threading.Thread(target=self._do_reconnect, daemon=True).start()

    def _do_reconnect(self):
        time.sleep(RECONNECT_DELAY)
        with self.lock:
            self._reconnect_pending = False
            if self.loading or not self.active or self.unloading: return
            self._reconnect_attempts += 1; attempts = self._reconnect_attempts
        if attempts > MAX_RECONNECTS:
            with self.lock: self._reconnect_attempts = 0
            run_on_ui_thread(lambda: BulletinHelper.show_error("❌ Не удалось переподключиться")); return
        if self.proxy_list:
            self._apply_proxy(self.proxy_list[self.current_index])
            with self.lock: self._reconnect_attempts = 0
            run_on_ui_thread(lambda: BulletinHelper.show_success("✅ Переподключено"))

    # ─── хуки SharedConfig ───────────────────

    def _install_hooks(self):
        if self.unloading: return
        try:
            SC = find_class("org.telegram.messenger.SharedConfig")
            CM = find_class("org.telegram.tgnet.ConnectionsManager")
            if SC:
                for name, hook in [
                    ("addProxy",        BlockProxyHook(self)),
                    ("deleteProxy",     BlockDeleteHook(self)),
                    ("setCurrentProxy", BlockProxyHook(self)),
                    ("isProxyEnabled",  ProxyEnabledHook(self)),
                    ("getCurrentProxy", CurrentProxyHook(self)),
                ]:
                    try:
                        h = self.hook_all_methods(SC, name, hook)
                        if h: self._all_hooks.append(h)
                    except: pass
            if CM:
                try:
                    h = self.hook_all_methods(CM, "getConnectionState", ConnectionStateHook(self))
                    if h: self._all_hooks.append(h)
                except: pass
        except Exception as e: self.log(f"hooks: {e}")

    def _unhook_all(self):
        self.active = False
        for h in list(self._all_hooks):
            try:
                if isinstance(h, list):
                    for x in h: self.unhook_method(x)
                else: self.unhook_method(h)
            except: pass
        self._all_hooks.clear()

    # ─── гео (ip-api) ────────────────────────

    def _load_ip_cache(self):
        try: self._ip_cache = json.loads(self.get_setting("ip_cache","{}"))
        except: self._ip_cache = {}

    def _save_ip_cache(self):
        try: self.set_setting("ip_cache", json.dumps(self._ip_cache))
        except: pass

    def _geo_ttl_ms(self): return GEO_TTL_DAYS[safe_int(self.get_setting("geo_ttl_idx",2),2)] * 86400 * 1000

    def _geo_fresh(self, addr: str):
        d = self._ip_cache.get(addr)
        if not d: return None
        if (int(time.time()*1000) - d.get("ts",0)) > self._geo_ttl_ms(): return None
        return d

    def _geo_request(self, addr: str):
        with self._batch_lock:
            if self._geo_fresh(addr) is not None: return
            if addr in self._pending_ips or addr in self._inflight_ips: return
            self._pending_ips.add(addr)
            if self._geo_running: return
            self._geo_running = True
        threading.Thread(target=self._geo_drain_loop, daemon=True).start()

    def _geo_drain_loop(self):
        try:
            import requests as req
            while not self.unloading:
                time.sleep(0.8)
                with self._batch_lock:
                    batch = list(self._pending_ips)[:100]
                    if not batch: self._geo_running = False; return
                    for ip in batch: self._pending_ips.discard(ip); self._inflight_ips.add(ip)
                self._geo_fetch(req, batch)
                with self._batch_lock:
                    for ip in batch: self._inflight_ips.discard(ip)
        except Exception as e:
            log(f"pm: geo loop {e}")
            with self._batch_lock: self._geo_running = False

    def _geo_fetch(self, req, hosts):
        try:
            import socket as _s, re as _re
            queries = []
            for h in hosts:
                try:
                    ip = h if _re.match(r"^\d{1,3}(\.\d{1,3}){3}$",h) else _s.gethostbyname(h)
                except: ip = h
                queries.append({"query": ip})
            resp = req.post("http://ip-api.com/batch?fields=query,countryCode,isp,status",
                            json=queries, timeout=10)
            if resp.status_code == 429:
                with self._batch_lock:
                    for h in hosts: self._pending_ips.add(h)
                time.sleep(5); return
            data = resp.json(); now = int(time.time()*1000); changed = False
            for i, item in enumerate(data):
                if i >= len(hosts): break
                host = hosts[i]; cc = item.get("countryCode"); isp = item.get("isp","") or ""
                isp = re.sub(r"(?i)\s+(LLC|Inc\.|Ltd\.|Corporation|Corp\.|Hosting|Network|Communications|GmbH)","",isp).strip(" ,.")
                if len(isp) > 18: isp = isp[:16]+".."
                if cc:
                    flag = chr(ord(cc[0])+127397)+chr(ord(cc[1])+127397)
                    self._ip_cache[host] = {"flag":flag,"isp":isp,"cc":cc,"ts":now}; changed = True
                else:
                    self._ip_cache[host] = {"flag":"","isp":"","cc":"","ts":now}; changed = True
            if changed:
                if len(self._ip_cache) > 2000:
                    ordered = sorted(self._ip_cache.items(), key=lambda kv: kv[1].get("ts",0))
                    for k,_ in ordered[:len(self._ip_cache)-2000]: self._ip_cache.pop(k,None)
                self._save_ip_cache()
                run_on_ui_thread(self._notify_proxy_settings_changed)
        except Exception as e: log(f"pm: geo fetch {e}")

    # ─── импорт / экспорт / управление ───────

    def _export_plugin_settings(self, view=None):
        """Экспортирует все настройки плагина в JSON и отправляет в Избранное."""
        def task():
            try:
                data = self.export_settings()
                txt  = json.dumps(data, ensure_ascii=False, indent=2)
                uid  = get_user_config().getClientUserId()
                send_message({"peer": uid, "message": f"```json\n{txt}\n```"})
                run_on_ui_thread(lambda: BulletinHelper.show_success(
                    "📤 Настройки отправлены в Избранное"))
            except Exception as e:
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка: {e}"))
        threading.Thread(target=task, daemon=True).start()

    def _import_plugin_settings(self, view=None):
        """Импортирует настройки из буфера обмена."""
        def ui():
            try:
                clip = ApplicationLoader.applicationContext.getSystemService("clipboard")
                if not clip or not clip.hasPrimaryClip():
                    BulletinHelper.show_error("Буфер пуст"); return
                raw = str(clip.getPrimaryClip().getItemAt(0).getText() or "")
                # Убираем markdown блок если есть
                raw = re.sub(r"```json\n?|```", "", raw).strip()
                data = json.loads(raw)
                self.import_settings(data, reload_settings=True)
                BulletinHelper.show_success("✅ Настройки импортированы!")
            except Exception as e:
                BulletinHelper.show_error(f"Ошибка импорта: {e}")
        run_on_ui_thread(ui)


    def _check_orbot_btn(self, view=None):
        """Кнопка ручной проверки Orbot в настройках."""
        if not is_orbot_installed():
            run_on_ui_thread(lambda: BulletinHelper.show_error(
                "❌ Orbot не установлен. Скачай из Play Market: Orbot: Tor on Android"))
            return
        run_on_ui_thread(lambda: BulletinHelper.show_info("🧅 Проверяю Orbot..."))
        def check():
            running = is_orbot_running()
            if not running:
                run_on_ui_thread(lambda: BulletinHelper.show_error(
                    "⚠️ Orbot установлен, но не запущен. Открой и нажми Start."))
                return
            ping = check_orbot_proxy(timeout=10)
            if ping < 9999.0:
                run_on_ui_thread(lambda: BulletinHelper.show_success(
                    f"✅ Orbot работает • {ping:.0f} мс"))
            else:
                run_on_ui_thread(lambda: BulletinHelper.show_error(
                    "❌ Orbot запущен но не отвечает. Подожди пока Tor поднимется."))
        threading.Thread(target=check, daemon=True).start()

    def _show_history(self, view=None):
        """Показывает историю переключений."""
        hist = self._history.format_last(20)
        act = self._activity()
        if act is None:
            run_on_ui_thread(lambda: BulletinHelper.show_info(hist[:200]))
            return
        def ui():
            try:
                from ui.alert import AlertDialogBuilder
                b = AlertDialogBuilder(act)
                b.set_title("📈 История переключений (последние 20)")
                b.set_message(hist)
                b.set_positive_button("OK", lambda bld,w: bld.dismiss())
                b.show()
            except Exception as e:
                log(f"pm: history dialog {e}")
        run_on_ui_thread(ui)

    def _show_favorites_menu(self, view=None):
        """Меню управления избранными прокси."""
        if not self.proxy_list:
            run_on_ui_thread(lambda: BulletinHelper.show_error("❌ Нет прокси в пуле"))
            return
        entries = []
        for p in self.proxy_list[:20]:  # показываем первые 20
            is_fav = self._favorites.is_favorite(p)
            star = "⭐" if is_fav else "  "
            label = f"{star} {proxy_label(p)}"
            def toggle(px=p):
                if self._favorites.is_favorite(px):
                    self._favorites.remove(px)
                    run_on_ui_thread(lambda: BulletinHelper.show_info(f"Убрано из избранного: {px['server']}"))
                else:
                    self._favorites.add(px)
                    run_on_ui_thread(lambda: BulletinHelper.show_success(f"⭐ Добавлено в избранное: {px['server']}"))
            entries.append((label, toggle))
        entries.append(("🗑 Очистить все избранные", lambda: [
            self._favorites._favorites.clear(),
            self._favorites._save(),
            run_on_ui_thread(lambda: BulletinHelper.show_success("Избранные очищены"))
        ]))
        self._show_action_menu(None, f"⭐ Избранные прокси (всего: {self._favorites.count()})", entries)


    def _activity(self, fragment=None):
        try:
            fr = fragment or get_last_fragment()
            return fr.getParentActivity() if fr else None
        except: return None

    def _show_action_menu(self, fragment, title, entries):
        act = self._activity(fragment)
        if act is None: BulletinHelper.show_error("Нет активити"); return
        def ui():
            try:
                from ui.alert import AlertDialogBuilder
                b = AlertDialogBuilder(act); b.set_title(title)
                labels = [e[0] for e in entries]
                def on_item(bld, which):
                    try: bld.dismiss()
                    except: pass
                    try: entries[which][1]()
                    except Exception as e: BulletinHelper.show_error(f"Ошибка: {e}")
                b.set_items(labels, on_item)
                b.set_negative_button("Отмена", lambda bld,w: bld.dismiss())
                b.show()
            except Exception as e: log(f"pm: action menu {e}")
        run_on_ui_thread(ui)

    def _open_import_menu(self, fragment=None):
        self._show_action_menu(fragment, "Импорт прокси", [
            ("📋 Из буфера обмена", self._import_from_clipboard),
            ("🌐 Из URL",           lambda: self._ask_text(fragment, "URL", "https://…", self._import_from_url)),
            ("✏️ Вставить текст",   lambda: self._ask_text(fragment, "Вставьте ссылки", "tg://proxy?…", self._import_from_text)),
        ])

    def _open_export_menu(self, fragment=None):
        self._show_action_menu(fragment, "Экспорт прокси", [
            ("Все → Избранное",        lambda: self._export_proxies(False,False)),
            ("Только рабочие → Избранное", lambda: self._export_proxies(True,False)),
            ("Все → Буфер",            lambda: self._export_proxies(False,True)),
            ("Только рабочие → Буфер", lambda: self._export_proxies(True,True)),
        ])

    def _open_manage_menu(self, fragment=None):
        self._show_action_menu(fragment, "Управление прокси", [
            ("📊 Сортировать по пингу",    self._sort_by_ping),
            ("🗑 Удалить мёртвые",         self._remove_dead),
            ("🔁 Удалить дубликаты",       self._dedup),
            ("✅ Оставить только рабочие", self._keep_working),
            ("🛡️ Оставить только FakeTLS", self._keep_faketls),
            ("⚠️ Удалить plain MTProto",   self._remove_plain),
            ("🌍 Фильтр по стране",        lambda: self._filter_country_menu(fragment)),
        ])

    def _ask_text(self, fragment, title, hint, on_result):
        act = self._activity(fragment)
        if act is None: return
        def ui():
            try:
                from ui.alert import AlertDialogBuilder
                from android.widget import EditText, LinearLayout
                from android.view import ViewGroup
                from org.telegram.ui.ActionBar import Theme
                container = LinearLayout(act); container.setOrientation(LinearLayout.VERTICAL)
                pad = AndroidUtilities.dp(20); container.setPadding(pad,AndroidUtilities.dp(8),pad,AndroidUtilities.dp(8))
                edit = EditText(act); edit.setHint(hint)
                try: edit.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
                except: pass
                container.addView(edit, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
                b = AlertDialogBuilder(act); b.set_title(title); b.set_view(container)
                def ok(bld,w):
                    val = str(edit.getText().toString())
                    try: bld.dismiss()
                    except: pass
                    if val.strip(): on_result(val)
                b.set_positive_button("OK", ok)
                b.set_negative_button("Отмена", lambda bld,w: bld.dismiss())
                b.show()
            except Exception as e: log(f"pm: ask text {e}")
        run_on_ui_thread(ui)

    def _existing_keys(self):
        try: SharedConfig.loadProxyList(); return set(_proxy_key(p) for p in _jlist_to_py(SharedConfig.proxyList))
        except: return set()

    def _parse_and_add(self, text):
        text = (text or "").replace("tg://", " tg://").replace("https://t.me/", " https://t.me/")
        links = re.findall(r"(tg://[^\s\"'<>]+|https?://t\.me/[^\s\"'<>]+)", text)
        if not links: return None
        ProxyInfo = jclass("org.telegram.messenger.SharedConfig$ProxyInfo")
        existing = self._existing_keys(); added = 0
        for lnk in links:
            if "proxy?" not in lnk and "socks?" not in lnk: continue
            lnk = lnk.replace("https://t.me/", "tg://")
            try:
                parsed = urllib.parse.urlsplit(lnk.replace("tg://","http://"))
                q = urllib.parse.parse_qs(parsed.query)
            except: continue
            srv = q.get("server",[""])[0]; port = q.get("port",["0"])[0]
            if not srv or not port.isdigit(): continue
            pnum = int(port)
            if not (0 < pnum <= 65535): continue
            user = urllib.parse.unquote(q.get("user",[""])[0])
            pwd  = urllib.parse.unquote(q.get("pass",[""])[0])
            secret = q.get("secret",[""])[0]
            k = (srv, pnum, secret, user, pwd)
            if k in existing: continue
            try:
                info = ProxyInfo(srv, pnum, user, pwd, secret)
                SharedConfig.addProxy(info); existing.add(k); added += 1
            except Exception as e: log(f"pm: addProxy {e}")
        return added

    def _finish_import(self, added):
        if added is None: BulletinHelper.show_error("Прокси-ссылок не найдено"); return
        if added > 0:
            try: SharedConfig.saveProxyList(); self._notify_proxy_settings_changed()
            except: pass
            BulletinHelper.show_success(f"✅ Импортировано: {added}")
        else: BulletinHelper.show_info("Новых прокси не найдено")

    def _import_from_clipboard(self):
        def ui():
            try:
                clip = ApplicationLoader.applicationContext.getSystemService("clipboard")
                if not clip or not clip.hasPrimaryClip():
                    BulletinHelper.show_error("Буфер пуст"); return
                raw = str(clip.getPrimaryClip().getItemAt(0).getText() or "")
                self._finish_import(self._parse_and_add(raw))
            except Exception as e: BulletinHelper.show_error(f"Ошибка: {e}")
        run_on_ui_thread(ui)

    def _import_from_text(self, text):
        run_on_ui_thread(lambda: self._finish_import(self._parse_and_add(text)))

    def _import_from_url(self, url):
        def task():
            try:
                u = url.strip()
                if not u.startswith("http"): u = "https://"+u
                import requests; body = requests.get(u, timeout=15).text
                run_on_ui_thread(lambda: self._finish_import(self._parse_and_add(body)))
            except Exception as e:
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка загрузки: {e}"))
        threading.Thread(target=task, daemon=True).start()

    def _build_export_text(self, proxies):
        mt, sk = [], []
        for p in proxies:
            secret = str(getattr(p,"secret","") or "").strip()
            if secret: mt.append(f"tg://proxy?server={p.address}&port={p.port}&secret={secret}")
            else: sk.append(f"tg://socks?server={p.address}&port={p.port}&user={p.username}&pass={p.password}")
        txt = f"Proxies ({len(proxies)}):\n\n"
        if sk: txt += "SOCKS5:\n"+"\n".join(sk)+"\n\n"
        if mt: txt += "MTProto:\n"+"\n".join(mt)
        return txt

    def _export_proxies(self, only_working=False, to_clipboard=False):
        def task():
            try:
                SharedConfig.loadProxyList(); proxies = _jlist_to_py(SharedConfig.proxyList)
                if only_working: proxies = [p for p in proxies if getattr(p,"available",False)]
                if not proxies: run_on_ui_thread(lambda: BulletinHelper.show_error("Нет прокси для экспорта")); return
                txt = self._build_export_text(proxies)
                if to_clipboard:
                    try:
                        from android_utils import copy_to_clipboard; copy_to_clipboard(txt)
                    except:
                        try: AndroidUtilities.addToClipboard(txt)
                        except: pass
                    run_on_ui_thread(lambda: BulletinHelper.show_success(f"📋 Скопировано: {len(proxies)}")); return
                uid = get_user_config().getClientUserId()
                if len(txt.encode("utf-16-le"))//2 > 4000:
                    fp = os.path.join(get_plugins_dir(), "proxies_export.txt")
                    write_file(fp, txt); send_document(uid, fp, caption="Proxy Manager Pro export")
                    run_on_ui_thread(lambda: BulletinHelper.show_success("📤 Экспорт → Избранное (файл)"))
                else:
                    q = TLRPC.TL_messageEntityBlockquote(); q.collapsed=True; q.offset=0; q.length=len(txt.encode("utf-16-le"))//2
                    send_message({"peer":uid,"message":txt,"entities":[q]})
                    run_on_ui_thread(lambda: BulletinHelper.show_success("📤 Экспорт → Избранное"))
            except Exception as e:
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка: {e}"))
        threading.Thread(target=task, daemon=True).start()

    def _rewrite_list(self, keep_pred, result_kind):
        def ui():
            try:
                SharedConfig.loadProxyList(); al = SharedConfig.proxyList
                items = _jlist_to_py(al); cur = getattr(SharedConfig,"currentProxy",None)
                kept = []; removed = 0; active_saved = False
                for it in items:
                    if it is cur: kept.append(it);
                    elif keep_pred(it): kept.append(it)
                    else: removed += 1
                if removed == 0: BulletinHelper.show_info("Нечего удалять"); return
                al.clear()
                for it in kept: al.add(it)
                SharedConfig.saveProxyList(); self._notify_proxy_settings_changed()
                if result_kind == "keep": BulletinHelper.show_success(f"Оставлено: {len(kept)} (удалено {removed})")
                else: BulletinHelper.show_success(f"Удалено: {removed}")
            except Exception as e: BulletinHelper.show_error(f"Ошибка: {e}")
        run_on_ui_thread(ui)

    def _remove_dead(self):
        self._rewrite_list(lambda p: bool(getattr(p,"available",False)) or int(getattr(p,"availableCheckTime",0) or 0)==0, "remove")
    def _keep_working(self): self._rewrite_list(lambda p: bool(getattr(p,"available",False)), "keep")
    def _keep_faketls(self): self._rewrite_list(lambda p: _classify_proxy(p)["type"]=="faketls", "keep")
    def _remove_plain(self): self._rewrite_list(lambda p: _classify_proxy(p)["type"]!="plain", "remove")

    def _dedup(self):
        def ui():
            try:
                SharedConfig.loadProxyList(); al = SharedConfig.proxyList
                items = _jlist_to_py(al); cur = getattr(SharedConfig,"currentProxy",None)
                seen = set(); kept = []; removed = 0
                for it in items:
                    k = _proxy_key(it)
                    if it is cur or k not in seen: seen.add(k); kept.append(it)
                    else: removed += 1
                if removed == 0: BulletinHelper.show_info("Нечего удалять"); return
                al.clear()
                for it in kept: al.add(it)
                SharedConfig.saveProxyList(); self._notify_proxy_settings_changed()
                BulletinHelper.show_success(f"Удалено дубликатов: {removed}")
            except Exception as e: BulletinHelper.show_error(f"Ошибка: {e}")
        run_on_ui_thread(ui)

    def _sort_by_ping(self, fragment=None):
        def ui():
            try:
                SharedConfig.loadProxyList(); al = SharedConfig.proxyList
                items = _jlist_to_py(al)
                if len(items) <= 1: BulletinHelper.show_info("Нечего сортировать"); return
                def sk(i):
                    av = bool(getattr(i,"available",False)); p = int(getattr(i,"ping",0) or 0)
                    if not av or p <= 0: return (1,0)
                    return (0,p)
                items.sort(key=sk); al.clear()
                for it in items: al.add(it)
                SharedConfig.saveProxyList(); self._notify_proxy_settings_changed()
                BulletinHelper.show_success("✅ Отсортировано по пингу")
            except Exception as e: BulletinHelper.show_error(f"Ошибка: {e}")
        run_on_ui_thread(ui)

    def _filter_country_menu(self, fragment=None):
        try:
            SharedConfig.loadProxyList(); items = _jlist_to_py(SharedConfig.proxyList)
            counts = {}
            for it in items:
                addr = str(getattr(it,"address","") or ""); d = self._ip_cache.get(addr)
                if d and d.get("cc"):
                    cc = d["cc"]; flag = d.get("flag","")
                    counts.setdefault(cc, [0,flag]); counts[cc][0] += 1
            if not counts: BulletinHelper.show_info("Нет данных о странах"); return
            entries = []
            for cc in sorted(counts.keys()):
                cnt, flag = counts[cc]
                entries.append((f"{flag} {cc} ({cnt})", lambda c=cc: self._keep_country(c)))
            self._show_action_menu(fragment, "Оставить только страну", entries)
        except Exception as e: BulletinHelper.show_error(f"Ошибка: {e}")

    def _keep_country(self, cc):
        def pred(p):
            addr = str(getattr(p,"address","") or ""); d = self._ip_cache.get(addr)
            if not d: return True
            pc = d.get("cc"); return True if not pc else pc == cc
        self._rewrite_list(pred, "keep")
