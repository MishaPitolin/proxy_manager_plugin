#  ГОНКА ПРОКСИ
# ═══════════════════════════════════════════════════════════════════

class ProxyRace:
    def __init__(self, proxies, on_winner, on_done, timeout=NATIVE_TIMEOUT):
        self.proxies = proxies; self.on_winner = on_winner; self.on_done = on_done
        self.timeout = timeout
        self._winner_set = threading.Event(); self._results = []; self._lock = threading.Lock()
    def start(self):
        threading.Thread(target=self._run, daemon=True, name="pm-race").start()
    def _run(self):
        try:
            with ThreadPoolExecutor(max_workers=RACE_WORKERS) as ex:
                list(ex.map(self._check_one, self.proxies))
        finally:
            with self._lock: results = sorted(self._results, key=proxy_score)
            self.on_done(results)
    def _check_one(self, p):
        if tcp_alive(p["server"], p["port"]) >= 9999.0: return
        ping = check_proxy_real(p, self.timeout)
        if ping >= 9999.0: return
        p["ping"] = ping
        with self._lock:
            self._results.append(p); first = not self._winner_set.is_set()
        if first: self._winner_set.set(); self.on_winner(p)
        spd = speed_test(p)
        if spd > 0: p["speed_kbps"] = spd


