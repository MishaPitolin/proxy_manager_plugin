NOTIF_CHANNEL_ID = "proxy_manager_status"
NOTIF_ID         = 7771

def _create_notif_channel():
    try:
        from android.app import NotificationChannel, NotificationManager
        from android.graphics import Color
        ctx = ApplicationLoader.applicationContext
        nm  = ctx.getSystemService("notification")
        if nm.getNotificationChannel(NOTIF_CHANNEL_ID) is None:
            ch = NotificationChannel(
                NOTIF_CHANNEL_ID, "Proxy Manager", NotificationManager.IMPORTANCE_LOW)
            ch.setDescription("Статус прокси подключения")
            ch.setShowBadge(False)
            ch.enableLights(False)
            ch.enableVibration(False)
            nm.createNotificationChannel(ch)
    except Exception as e:
        log(f"pm: notif channel {e}")

def _show_status_notification(title: str, text: str):
    try:
        from android.app import Notification, NotificationManager, PendingIntent
        from android.content import Intent
        ctx = ApplicationLoader.applicationContext
        _create_notif_channel()

        # Intent чтобы открыть настройки плагина при тапе
        intent = ctx.getPackageManager().getLaunchIntentForPackage(ctx.getPackageName())
        if intent:
            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
        pi = PendingIntent.getActivity(ctx, 0, intent,
            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE) if intent else None

        builder = Notification.Builder(ctx, NOTIF_CHANNEL_ID)
        builder.setSmallIcon(R_tg.drawable.msg2_proxy)
        builder.setContentTitle(title)
        builder.setContentText(text)
        builder.setOngoing(True)     # постоянное уведомление
        builder.setShowWhen(False)
        builder.setOnlyAlertOnce(True)
        if pi: builder.setContentIntent(pi)

        nm = ctx.getSystemService("notification")
        nm.notify(NOTIF_ID, builder.build())
    except Exception as e:
        log(f"pm: notif show {e}")

def _hide_status_notification():
    try:
        ctx = ApplicationLoader.applicationContext
        nm  = ctx.getSystemService("notification")
        nm.cancel(NOTIF_ID)
    except Exception as e:
        log(f"pm: notif hide {e}")


# ═══════════════════════════════════════════════════════════════════
#  ORBOT (TOR) — РЕЗЕРВНЫЙ ВАРИАНТ
# ═══════════════════════════════════════════════════════════════════

def is_orbot_installed() -> bool:
    """Проверяет установлен ли Orbot."""
    try:
        ctx = ApplicationLoader.applicationContext
        pm = ctx.getPackageManager()
        pm.getPackageInfo(ORBOT_PACKAGE, 0)
        return True
    except: return False

def is_orbot_running() -> bool:
    """Проверяет запущен ли Tor через Orbot (порт 9050 слушает)."""
    try:
        with socket.create_connection(("127.0.0.1", ORBOT_SOCKS5_PORT), timeout=2):
            return True
    except: return False

def start_orbot():
    """Запускает Orbot через Intent если установлен."""
    try:
        from android.content import Intent
        from android.net import Uri
        ctx = ApplicationLoader.applicationContext
        intent = Intent("org.torproject.android.intent.action.START")
        intent.setPackage(ORBOT_PACKAGE)
        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
        ctx.startService(intent)
        return True
    except Exception as e:
        log(f"pm: orbot start {e}")
        return False

def open_orbot():
    """Открывает приложение Orbot."""
    try:
        from android.content import Intent
        ctx = ApplicationLoader.applicationContext
        pm = ctx.getPackageManager()
        intent = pm.getLaunchIntentForPackage(ORBOT_PACKAGE)
        if intent:
            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            ctx.startActivity(intent)
            return True
    except Exception as e:
        log(f"pm: orbot open {e}")
    return False

def check_orbot_proxy(timeout: int = 10) -> float:
    """Проверяет работает ли Tor через Orbot и возвращает пинг."""
    if not is_orbot_running(): return 9999.0
    # Проверяем через SOCKS5 хэндшейк
    result = _check_socks5("127.0.0.1", ORBOT_SOCKS5_PORT, "", "", timeout)
    return float(result) if result > 0 else 9999.0


# ═══════════════════════════════════════════════════════════════════
#  СТАТИСТИКА И ИЗБРАННЫЕ ПРОКСИ
# ═══════════════════════════════════════════════════════════════════

class ProxyStats:
    """Считает uptime, среднее пинг и использование каждого прокси."""
    def __init__(self, path: str):
        self.path = path
        self._data: Dict[str, Dict] = {}
        self._load()
        self._lock = threading.Lock()

    def _key(self, p: dict) -> str:
        return f"{p['server']}:{p['port']}"

    def _load(self):
        try:
            with open(self.path) as f:
                self._data = json.load(f)
        except: self._data = {}

    def _save(self):
        try:
            with open(self.path, "w") as f:
                json.dump(self._data, f)
        except: pass

    def record_connect(self, p: dict, ping: float):
        k = self._key(p)
        with self._lock:
            d = self._data.setdefault(k, {
                "uses": 0, "total_ping": 0.0, "failures": 0,
                "last_used": 0, "first_seen": int(time.time())
            })
            d["uses"] += 1
            d["total_ping"] += ping
            d["last_used"] = int(time.time())
        self._save()

    def record_failure(self, p: dict):
        k = self._key(p)
        with self._lock:
            d = self._data.setdefault(k, {"uses": 0, "total_ping": 0.0, "failures": 0, "last_used": 0, "first_seen": int(time.time())})
            d["failures"] += 1
        self._save()

    def avg_ping(self, p: dict) -> float:
        k = self._key(p)
        with self._lock:
            d = self._data.get(k, {})
            uses = d.get("uses", 0)
            return d.get("total_ping", 0) / uses if uses > 0 else 0.0

    def uptime(self, p: dict) -> float:
        k = self._key(p)
        with self._lock:
            d = self._data.get(k, {})
            uses = d.get("uses", 0); fail = d.get("failures", 0)
            total = uses + fail
            return (uses / total * 100) if total > 0 else 0.0

    def uses(self, p: dict) -> int:
        k = self._key(p)
        with self._lock: return self._data.get(k, {}).get("uses", 0)

    def summary(self, p: dict) -> str:
        return (f"Использований: {self.uses(p)} • "
                f"Avg пинг: {self.avg_ping(p):.0f}мс • "
                f"Uptime: {self.uptime(p):.0f}%")

    def top(self, proxies: List[Dict], n: int = 5) -> List[Dict]:
        """Возвращает топ N прокси по uptime."""
        return sorted(proxies, key=lambda p: self.uptime(p), reverse=True)[:n]


class FavoriteProxies:
    """Список избранных прокси — всегда пробуются первыми."""
    def __init__(self, path: str):
        self.path = path
        self._favorites: List[str] = []  # список ключей "server:port"
        self._load()
        self._lock = threading.Lock()

    def _key(self, p: dict) -> str: return f"{p['server']}:{p['port']}"

    def _load(self):
        try:
            with open(self.path) as f: self._favorites = json.load(f)
        except: self._favorites = []

    def _save(self):
        try:
            with open(self.path, "w") as f: json.dump(self._favorites, f)
        except: pass

    def add(self, p: dict):
        k = self._key(p)
        with self._lock:
            if k not in self._favorites: self._favorites.append(k)
        self._save()

    def remove(self, p: dict):
        k = self._key(p)
        with self._lock:
            if k in self._favorites: self._favorites.remove(k)
        self._save()

    def is_favorite(self, p: dict) -> bool:
        with self._lock: return self._key(p) in self._favorites

    def prioritize(self, proxies: List[Dict]) -> List[Dict]:
        """Ставит избранные прокси в начало списка."""
        favs = [p for p in proxies if self.is_favorite(p)]
        rest = [p for p in proxies if not self.is_favorite(p)]
        return favs + rest

    def count(self) -> int:
        with self._lock: return len(self._favorites)


class SwitchHistory:
    """История переключений прокси."""
    def __init__(self, path: str, max_entries: int = 100):
        self.path = path; self.max_entries = max_entries
        self._history: List[Dict] = []; self._lock = threading.Lock()
        self._load()

    def _load(self):
        try:
            with open(self.path) as f: self._history = json.load(f)
        except: self._history = []

    def _save(self):
        try:
            with open(self.path, "w") as f: json.dump(self._history, f)
        except: pass

    def record(self, proxy: dict, reason: str, ping: float):
        entry = {
            "ts": int(time.time()),
            "server": proxy["server"], "port": proxy["port"],
            "type": proxy.get("type", "mtproto"),
            "ping": ping, "reason": reason,
            "dt": datetime.now().strftime("%d.%m %H:%M")
        }
        with self._lock:
            self._history.append(entry)
            if len(self._history) > self.max_entries:
                self._history = self._history[-self.max_entries:]
        self._save()

    def last(self, n: int = 10) -> List[Dict]:
        with self._lock: return list(reversed(self._history[-n:]))

    def format_last(self, n: int = 10) -> str:
        entries = self.last(n)
        if not entries: return "История пуста"
        lines = []
        for e in entries:
            tp = "MT" if e["type"] == "mtproto" else "S5"
            lines.append(f"{e['dt']} [{tp}] {e['server']} • {e['ping']:.0f}мс • {e['reason']}")
        return "\n".join(lines)


class ProxyCache:
    def __init__(self, path=CACHE_FILE): self.path = path
    def save(self, proxies):
        try:
            with open(self.path, "w") as f: json.dump({"ts": time.time(), "proxies": proxies}, f)
        except: pass
    def load(self, max_age=3600):
        try:
            with open(self.path) as f: data = json.load(f)
            if time.time()-data.get("ts",0) < max_age: return data.get("proxies",[])
        except: pass
        return []
    def clear(self):
        try: os.remove(self.path)
        except: pass

class Blacklist:
    def __init__(self):
        self._strikes: Dict[str,int] = {}; self._banned: Dict[str,float] = {}
        self._lock = threading.Lock()
    def _key(self, p): return f"{p['server']}:{p['port']}"
    def strike(self, p):
        k = self._key(p)
        with self._lock:
            self._strikes[k] = self._strikes.get(k,0)+1
            if self._strikes[k] >= BL_STRIKES:
                self._banned[k] = time.time()+BL_TTL; self._strikes[k] = 0
    def is_banned(self, p):
        k = self._key(p)
        with self._lock:
            until = self._banned.get(k, 0)
            if until and time.time() < until: return True
            if until: del self._banned[k]
            return False
    def reset(self, p):
        k = self._key(p)
        with self._lock: self._strikes.pop(k,None); self._banned.pop(k,None)
    def filter(self, proxies): return [p for p in proxies if not self.is_banned(p)]
    def banned_count(self): return len(self._banned)
    def clear(self):
        with self._lock: self._strikes.clear(); self._banned.clear()

class Prefetcher:
    def __init__(self, get_list, get_idx, n=PREFETCH_COUNT):
        self._gl = get_list; self._gi = get_idx; self._n = n; self._running = False
    def start(self):
        if self._running: return
        self._running = True
        threading.Thread(target=self._loop, daemon=True, name="pm-prefetch").start()
    def stop(self): self._running = False
    def _loop(self):
        try:
            while self._running:
                time.sleep(20)
                if not self._running: break
                proxies = self._gl()
                if not proxies: continue
                idx = self._gi()
                cands = [proxies[(idx+i)%len(proxies)] for i in range(1, self._n+1)]
                def warm(p):
                    ti = safe_int(None, 1); timeout = TIMEOUTS[min(ti, len(TIMEOUTS)-1)]
                    ping = check_proxy_real(p, timeout)
                    if ping < 9999.0: p["ping"] = ping; p["prefetched"] = True
                with ThreadPoolExecutor(max_workers=self._n) as ex: list(ex.map(warm, cands))
        finally: self._running = False

class LocalLogger:
    def __init__(self, path=LOG_FILE):
        self.path = path; self._lock = threading.Lock(); self._lines: List[str] = []
        self._load()
    def _load(self):
        try:
            with open(self.path) as f: self._lines = f.read().splitlines()[-MAX_LOG_LINES:]
        except: self._lines = []
    def write(self, msg: str):
        ts = datetime.now().strftime("%d.%m %H:%M:%S"); line = f"[{ts}] {msg}"
        with self._lock:
            self._lines.append(line)
            if len(self._lines) > MAX_LOG_LINES: self._lines = self._lines[-MAX_LOG_LINES:]
        try:
            with open(self.path, "a") as f: f.write(line+"\n")
        except: pass
    def export(self) -> str:
        with self._lock: return "\n".join(self._lines)
    def clear(self):
        with self._lock: self._lines = []
        try: os.remove(self.path)
        except: pass


