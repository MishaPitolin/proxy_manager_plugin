def safe_int(v, default=0):
    try: return int(v)
    except: return default

def _jlist_to_py(jl):
    out = []
    try:
        for i in range(jl.size()): out.append(jl.get(i))
    except: pass
    return out

def _post_proxy_check_done(info):
    try:
        NotificationCenter.getGlobalInstance().postNotificationName(
            NotificationCenter.proxyCheckDone, info)
    except: pass

def _secret_to_bytes(secret) -> bytes:
    s = str(secret or "").strip()
    if not s: return b""
    try:
        if re.fullmatch(r"[0-9a-fA-F]+", s) and len(s) % 2 == 0:
            return bytes.fromhex(s)
    except: pass
    try:
        t = s.replace("-", "+").replace("_", "/")
        t += "=" * (-len(t) % 4)
        return base64.b64decode(t)
    except: pass
    return b""

def _classify_proxy(info) -> dict:
    b = _secret_to_bytes(getattr(info, "secret", ""))
    if not b:
        return {"type": "socks", "domain": "", "badge_key": "socks",
                "badge": "🧦", "score": 0, "label": "SOCKS5"}
    first, n = b[0], len(b)
    if n == 16:
        return {"type": "plain", "domain": "", "badge_key": "plain",
                "badge": "⚠️", "score": 1, "label": "MTProto (plain)"}
    if first == 0xEE and n >= 17:
        dom = ""
        try: dom = b[17:].decode("utf-8", "replace").strip()
        except: pass
        good = bool(dom) and any(dom == d or dom.endswith("." + d) for d in _GOOD_FRONTS)
        if good:
            return {"type": "faketls", "domain": dom, "badge_key": "faketls_good",
                    "badge": "🛡️", "score": 4, "label": f"FakeTLS · {dom}"}
        return {"type": "faketls", "domain": dom, "badge_key": "faketls",
                "badge": "🔒", "score": 3, "label": f"FakeTLS · {dom or '?'}"}
    if first == 0xDD and n == 17:
        return {"type": "secured", "domain": "", "badge_key": "secured",
                "badge": "➿", "score": 2, "label": "MTProto (random-pad)"}
    return {"type": "plain", "domain": "", "badge_key": "plain",
            "badge": "⚠️", "score": 1, "label": "MTProto (plain)"}

def _build_faketls_secret(key_bytes: bytes, domain: str) -> str:
    return "ee" + key_bytes.hex() + domain.encode("utf-8").hex()

def _proxy_key(p) -> tuple:
    return (str(getattr(p, "address", "") or ""), int(getattr(p, "port", 0) or 0),
            str(getattr(p, "secret", "") or ""), str(getattr(p, "username", "") or ""),
            str(getattr(p, "password", "") or ""))

def _ping_color(ms: int) -> int:
    if ms <= 0: return COLOR_SLOW
    if ms < PING_FAST_MS: return COLOR_FAST
    if ms < PING_MID_MS: return COLOR_MID
    return COLOR_SLOW

def tcp_alive(host, port, timeout=TCP_TIMEOUT, use_doh=True):
    try:
        # Используем DoH для резолвинга чтобы обойти DNS блокировки
        resolved = resolve_host_doh(host) if use_doh else host
        t = time.monotonic()
        with socket.create_connection((resolved, int(port)), timeout=timeout):
            return (time.monotonic() - t) * 1000
    except: return 9999.0

def proxy_score(p) -> float:
    ping = p.get("ping", 9999)
    spd  = p.get("speed_kbps", 0)
    type_bonus = 0 if p.get("type") == PROXY_MTPROTO else 50
    if spd > 0: return (ping + type_bonus) / (1 + spd / 500)
    return ping + type_bonus

def proxy_label(p) -> str:
    tp   = "MTProto" if p.get("type") == PROXY_MTPROTO else "SOCKS5"
    ping = p.get("ping", 0)
    spd  = p.get("speed_kbps", 0)
    spd_str = f" • {spd:.0f}Кб/с" if spd > 0 else ""
    return f"[{tp}] {p['server']}:{p['port']} • {ping:.0f}мс{spd_str}"

def parse_all_proxies(text: str) -> List[Dict]:
    found, seen = [], set()
    for m in MTPROTO_RE.finditer(text):
        k = (m.group(1), m.group(2), PROXY_MTPROTO)
        if k not in seen:
            seen.add(k)
            found.append({"type": PROXY_MTPROTO, "server": m.group(1),
                "port": int(m.group(2)), "secret": m.group(3), "user": "", "pass": "",
                "link": f"tg://proxy?server={m.group(1)}&port={m.group(2)}&secret={m.group(3)}"})
    for m in SOCKS5_RE.finditer(text):
        k = (m.group(1), m.group(2), PROXY_SOCKS5)
        if k not in seen:
            seen.add(k)
            user = urllib.parse.unquote(m.group(3) or "")
            pwd  = urllib.parse.unquote(m.group(4) or "")
            found.append({"type": PROXY_SOCKS5, "server": m.group(1),
                "port": int(m.group(2)), "secret": "", "user": user, "pass": pwd,
                "link": f"tg://socks?server={m.group(1)}&port={m.group(2)}&user={user}&pass={pwd}"})
    return found

def extract_from_message(msg, max_age_days: int = 7) -> List[Dict]:
    """Парсит прокси из сообщения. Игнорирует сообщения старше max_age_days."""
    # Фильтр по дате — старые прокси обычно мертвы
    try:
        msg_date = getattr(msg, "date", 0) or 0
        if msg_date > 0:
            age_days = (time.time() - msg_date) / 86400
            if age_days > max_age_days:
                return []
    except: pass
    found = []
    txt = getattr(msg, "message", None) or ""
    if txt: found.extend(parse_all_proxies(txt))
    try:
        markup = getattr(msg, "reply_markup", None)
        if markup:
            for row in (getattr(markup, "rows", None) or []):
                for btn in (getattr(row, "buttons", None) or []):
                    url = getattr(btn, "url", None)
                    if url: found.extend(parse_all_proxies(url))
    except: pass
    return found

def fetch_from_web(username: str) -> List[Dict]:
    try:
        ctx = ssl.create_default_context()
        req = urllib.request.Request(
            f"https://t.me/s/{username}", headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=WEB_TIMEOUT, context=ctx) as r:
            return parse_all_proxies(r.read().decode("utf-8", errors="ignore"))
    except: return []

def speed_test(proxy: dict, timeout=5) -> float:
    for url in [f"https://{proxy['server']}/", "https://www.gstatic.com/generate_204"]:
        try:
            ctx = ssl.create_default_context()
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            t = time.monotonic()
            with urllib.request.urlopen(req, timeout=timeout, context=ctx) as r:
                data = r.read(SPEED_TEST_SIZE)
            elapsed = time.monotonic() - t
            if elapsed > 0 and len(data) > 100:
                return (len(data) * 8) / (elapsed * 1000)
        except: continue
    return 0.0


